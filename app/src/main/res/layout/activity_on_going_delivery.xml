<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".Activitys.OnGoingDeliveryActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f5f6f7">

        <LinearLayout
            android:id="@+id/linearTop"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="15dp"
                android:src="@drawable/back_ic"/>
            <TextView
                android:id="@+id/txt_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Ongoing Delivery"
                android:textSize="18sp"
                android:layout_weight="1"
                android:textColor="@color/black"/>
            <LinearLayout
                android:id="@+id/lnr_nav"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginRight="16dp"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_navigation"
                    />
            </LinearLayout>

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/linearTop"
            android:layout_above="@+id/linearBottom">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:text="Active Orders"
                    android:fontFamily="@font/teachers_medium"
                    android:textSize="18sp"
                    android:visibility="gone"
                    android:textColor="@color/black"/>

                <LinearLayout
                    android:id="@+id/lnr_order_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:padding="15dp"
                    android:orientation="vertical"
                    android:background="@drawable/round_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                        >
                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="20sp"
                                android:layout_height="20sp"
                                android:layout_centerVertical="true"
                                android:src="@drawable/profile_ic"/>
                            <TextView
                                android:id="@+id/txt_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:textSize="18sp"
                                android:text=""
                                android:singleLine="true"
                                android:fontFamily="@font/teachers_medium"
                                android:textColor="@color/black"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="25dp"
                            android:background="@color/gray"
                            android:layout_marginEnd="5dp"
                            android:layout_marginStart="5dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="16dp"
                            android:gravity="right|center_vertical"
                           >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:textSize="18sp"
                                android:text="ID: "
                                android:singleLine="true"
                                android:fontFamily="@font/teachers_regular"
                                android:textColor="@color/txtHeader"/>
                            <TextView
                                android:id="@+id/txt_order_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="18sp"
                                android:text=""
                                android:singleLine="true"
                                android:fontFamily="@font/teachers_medium"
                                android:textColor="@color/black"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:layout_weight="1">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20sp"
                            android:layout_height="20sp"
                            android:layout_gravity="start"
                            android:layout_centerVertical="true"
                            android:src="@drawable/marker_ic"/>
                        <TextView
                            android:id="@+id/txt_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textSize="18sp"
                            android:text=""
                            android:maxLines="3"
                            android:fontFamily="@font/teachers_regular"
                            android:textColor="@color/txtHeader"/>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/lnr_call"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/round_colorprimary_lightedge"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:layout_marginTop="15dp"
                    android:gravity="center"
                    android:layout_gravity="center">
                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_call"
                        android:tint="@color/white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Call to Customer"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="@font/teachers_medium"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/lnr_take_photo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:padding="15dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="@drawable/round_white">
                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edit_comment"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/round_edit_gray_light_edge"
                        android:layout_marginStart="10sp"
                        android:layout_marginEnd="10sp"
                        android:hint="Add your comments"
                        android:paddingHorizontal="12dp"
                        android:textSize="15sp"
                        android:minLines="2"
                        android:singleLine="true"
                        android:inputType="text"
                        android:minHeight="60dp"
                        android:textColorHint="@color/hintcolor"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Take photo of item"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/teachers_medium"
                        android:textSize="18sp"
                        android:textColor="@color/black"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Before hand over to customer item take photos"
                        android:textSize="14sp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        android:layout_marginEnd="65dp"
                        android:textColor="@color/txtHeader"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="* 2 photos"
                        android:textSize="14sp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        android:layout_marginEnd="65dp"
                        android:textColor="@color/txtHeader"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        >
                        <ImageView
                            android:id="@+id/img_one"
                            android:layout_width="80dp"
                            android:layout_margin="8dp"
                            android:layout_height="80dp"/>
                        <ImageView
                            android:id="@+id/img_two"
                            android:layout_width="80dp"
                            android:layout_margin="8dp"
                            android:layout_height="80dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/round_dot">


                        <LinearLayout
                            android:id="@+id/linear_take_photo"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/round_colorprimary_lightedge"
                            android:layout_marginStart="25dp"
                            android:layout_marginEnd="25dp"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="15dp"
                            android:gravity="center"
                            android:layout_gravity="center">
                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:tint="@color/white"
                                android:src="@drawable/camera_ic"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="Take a Photo"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:fontFamily="@font/teachers_medium"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:layout_marginTop="10dp"
                    android:padding="15sp"
                    android:background="@drawable/round_white"
                    android:gravity="center_vertical"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Parking Order"
                        android:fontFamily="@font/teachers_medium"
                        android:textSize="18sp"
                        android:textColor="@color/black"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Order ID: OD24654+6"
                        android:textSize="16sp"
                        android:layout_marginTop="3dp"
                        android:textColor="@color/txtHeader"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/lnr_delivered"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/round_colorprimary_lightedge"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:layout_marginTop="15dp"
                    android:visibility="gone"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Completed"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/teachers_semibold"/>
                    <TextView
                        android:id="@+id/txt_completed_order_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Order ID: OD123465"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="@font/teachers_regular"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/lnr_returned"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/red_button"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:layout_marginTop="15dp"
                    android:visibility="gone"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item(s) Returned"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/teachers_semibold"/>
                    <TextView
                        android:id="@+id/txt_completed_order_id_returned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Order ID: OD123465"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="@font/teachers_regular"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/img_photo"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="12dp"
                    android:visibility="gone"
                    android:layout_gravity="center_horizontal"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:padding="15sp"
                    android:background="@drawable/round_white"
                    android:gravity="center_vertical"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20sp"
                            android:layout_height="20sp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/bag_ic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:textSize="19sp"
                            android:text="Orders list"
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/black"/>
                        <TextView
                            android:id="@+id/txt_items"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="18sp"
                            android:text=""
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/txtHeader"/>
                    </LinearLayout>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:padding="15sp"
                    android:background="@drawable/round_white"
                    android:gravity="center_vertical"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="19sp"
                        android:text="Bill Details"
                        android:singleLine="true"
                        android:fontFamily="@font/teachers_medium"
                        android:textColor="@color/black"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/doc_ic"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:text="Bill Details"
                                android:singleLine="true"
                                android:fontFamily="@font/teachers_regular"
                                android:textColor="@color/black"/>
                            <TextView
                                android:id="@+id/txt_saved_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/round_light_blue"
                                android:padding="5dp"
                                android:text="Save ₹0"
                                android:textSize="13sp"
                                android:textColor="@color/splashcolor"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/txt_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="5dp"
                            android:layout_gravity="center_vertical"
                            android:textSize="16sp"
                            android:text=""
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_regular"
                            android:textColor="@color/gray"/>
                        <TextView
                            android:id="@+id/txt_bill_amnt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:textSize="18sp"
                            android:text=""
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/black"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/truck"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:text="GST Charges"
                                android:singleLine="true"
                                android:fontFamily="@font/teachers_regular"
                                android:textColor="@color/black"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/txt_gst_charages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:textSize="18sp"
                            android:text=""
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/black"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/truck"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:text="Delivery Charges"
                                android:singleLine="true"
                                android:fontFamily="@font/teachers_regular"
                                android:textColor="@color/black"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/delivery_charges_strike"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="5dp"
                            android:layout_gravity="center_vertical"
                            android:textSize="16sp"
                            android:text="₹49"
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_regular"
                            android:textColor="@color/gray"/>
                        <TextView
                            android:id="@+id/txt_delivery_charages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:textSize="18sp"
                            android:text=""
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/black"/>
                    </LinearLayout>
                    <TableRow
                        android:visibility="gone"
                        android:id="@+id/table_applied"
                        android:layout_width="match_parent"
                        android:layout_marginTop="12dp"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:src="@drawable/ic_coupon" />
                        <TextView
                            android:id="@+id/txt_amount_coupon"
                            android:layout_width="match_parent"
                            android:layout_weight="1"

                            android:layout_height="wrap_content"
                            android:text="Coupon Applied"
                            android:textColor="@color/green"
                            android:textStyle="bold" />

                    </TableRow>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="15dp"
                        android:background="@color/lightGray"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="18sp"
                            android:text="Grand Total"
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/black"/>
                        <TextView
                            android:id="@+id/txt_total_amnt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:textSize="18sp"
                            android:text=""
                            android:singleLine="true"
                            android:fontFamily="@font/teachers_medium"
                            android:textColor="@color/black"/>
                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>
        </ScrollView>


        <LinearLayout
            android:id="@+id/linearBottom"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/rounded_bottom_sheet">

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/linearReturned"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                android:layout_alignParentBottom="true"
                android:background="@drawable/red_button">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Returned"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="@font/teachers_medium" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/linearSubmit"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                android:background="@drawable/round_button">
                <TextView
                    android:id="@+id/txt_order_status"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Reached Customer"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="@font/teachers_medium" />
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>

</layout>